<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgCamera">

    <!-- Câmera ao vivo -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Guia de enquadramento -->
    <View
        android:id="@+id/frameGuide"
        android:layout_width="220dp"
        android:layout_height="80dp"
        android:background="@drawable/frame_guide"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Flash de captura -->
    <View
        android:id="@+id/overlayCapture"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#8000E676"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Label "Alinhe o display aqui" -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Alinhe o display da balança aqui"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp"
        android:background="#66000000"
        android:padding="4dp"
        app:layout_constraintTop_toTopOf="@id/frameGuide"
        app:layout_constraintBottom_toBottomOf="@id/frameGuide"
        app:layout_constraintStart_toStartOf="@id/frameGuide"
        app:layout_constraintEnd_toEndOf="@id/frameGuide"
        app:layout_constraintVertical_bias="0.08"/>

    <!-- Leitura atual em tempo real -->
    <TextView
        android:id="@+id/tvReading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="---"
        android:textSize="42sp"
        android:textStyle="bold"
        android:textColor="@color/colorReading"
        android:fontFamily="monospace"
        android:background="#AA000000"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="4dp"/>

    <!-- Barra de estabilidade -->
    <ProgressBar
        android:id="@+id/pbStability"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/colorStable"
        android:backgroundTint="#33FFFFFF"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Painel inferior -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bgPanel"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Status + contador -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Aguardando leitura..."
                android:textColor="@color/textPrimary"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 partículas"
                android:textColor="@color/colorAccent"
                android:textStyle="bold"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Lista compacta das últimas leituras -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMeasurements"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginBottom="8dp"/>

        <!-- Botões de controle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnPause"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="⏸ Pausar"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/colorPause"
                android:layout_marginEnd="4dp"
                style="@style/Widget.MaterialComponents.Button"/>

            <Button
                android:id="@+id/btnUndo"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="↩ Desfazer"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/colorUndo"
                android:layout_marginEnd="4dp"
                style="@style/Widget.MaterialComponents.Button"/>

            <Button
                android:id="@+id/btnExport"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="📊 Exportar"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/colorAccent"
                style="@style/Widget.MaterialComponents.Button"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
